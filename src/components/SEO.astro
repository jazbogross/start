---
type JsonLd = Record<string, any>;

import {
  parseSeoFrontmatter,
  parseSolidaryFrontmatter,
  toOpenGraphLocale
} from "../solidary-config/site";

const [solidaryEntry] = await Astro.glob("../content/solidary.md");
const [seoEntry] = await Astro.glob("../content/seo.md");
const solidary = parseSolidaryFrontmatter(solidaryEntry?.frontmatter);
const seo = parseSeoFrontmatter(seoEntry?.frontmatter);
const siteName = solidary.title;
const robotsDefault = seo.indexFollow ? solidary.robots || "index,follow" : "noindex,nofollow";
const customHeadHtml = seo.headHtml.trim();
const ogLocale = toOpenGraphLocale(seo.locale);

const {
  title,
  pageTitle = "",
  description,
  canonical,
  ogImage,
  ogDesc = description,
  ogImageAlt = "",
  robots = robotsDefault,
  jsonLd,
  ogType
} = Astro.props as {
  title: string;
  pageTitle?: string;
  description: string;
  canonical: string;
  ogImage?: string;
  ogDesc?: string;
  ogImageAlt?: string;
  robots?: string;
  jsonLd?: JsonLd | JsonLd[];
  ogType?: "website" | "article";
};

const siteTitle = title.trim() || siteName;
const trimmedPageTitle = pageTitle.trim();
const documentTitle =
  trimmedPageTitle && trimmedPageTitle !== siteTitle
    ? `${siteTitle} | ${trimmedPageTitle}`
    : siteTitle;
const jsonLdArray = seo.structuredData ? (Array.isArray(jsonLd) ? jsonLd : (jsonLd ? [jsonLd] : [])) : [];
const hasOgImage = Boolean(ogImage);

const computedOgType: "website" | "article" = ogType ?? (canonical.includes("/blog/") ? "article" : "website");

---

<title>{documentTitle}</title>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content={robots} />

{seo.openGraph && <meta property="og:type" content={computedOgType} />}
{seo.openGraph && <meta property="og:title" content={documentTitle} />}
{seo.openGraph && <meta property="og:description" content={ogDesc} />}
{seo.openGraph && <meta property="og:url" content={canonical} />}
{seo.openGraph && hasOgImage && <meta property="og:image" content={ogImage} />}
{seo.openGraph && hasOgImage && ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
{seo.openGraph && <meta property="og:site_name" content={siteName} />}
{seo.openGraph && <meta property="og:locale" content={ogLocale} />}


{seo.twitter && <meta name="twitter:card" content={hasOgImage ? "summary_large_image" : "summary"} />}
{seo.twitter && <meta name="twitter:title" content={documentTitle} />}
{seo.twitter && <meta name="twitter:description" content={ogDesc} />}
{seo.twitter && hasOgImage && <meta name="twitter:image" content={ogImage} />}

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="alternate icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

{customHeadHtml && <Fragment set:html={customHeadHtml} />}

{jsonLdArray.map((obj) => (
  <script type="application/ld+json" set:html={JSON.stringify(obj)} />
))}
