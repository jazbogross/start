---
import Base from "../layouts/Base.astro";
import { parseSeoFrontmatter, parseSolidaryFrontmatter } from "../solidary-config/site";
import { getEntry } from "astro:content";

const [solidaryEntry] = await Astro.glob("../content/solidary.md");
const [seoEntry] = await Astro.glob("../content/seo.md");
const solidary = parseSolidaryFrontmatter(solidaryEntry?.frontmatter);
const seo = parseSeoFrontmatter(seoEntry?.frontmatter);
const siteName = solidary.title;
const siteDescription = solidary.description;
const siteUrl = solidary.url;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  url: siteUrl,
  inLanguage: seo.locale
};

const homeEntry = await getEntry("pages", "home");
const { Content: HomeContent } = homeEntry ? await homeEntry.render() : { Content: null };
const homeJavaScript =
  typeof homeEntry?.data.javascript === "string" ? homeEntry.data.javascript.trim() : "";
const sanitizedHomeJavaScript = homeJavaScript.replaceAll("</script", "<\\/script");
---
<Base description={siteDescription} canonicalPath="/" jsonLd={jsonLd}>
  <article class="prose">
    {HomeContent ? <HomeContent /> : null}
  </article>
  {sanitizedHomeJavaScript && <script is:inline set:html={sanitizedHomeJavaScript} />}
</Base>
