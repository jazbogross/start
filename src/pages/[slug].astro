---
import Base from "../layouts/Base.astro";
import { parseSolidaryFrontmatter } from "../solidary-config/site";
import { getCollection } from "astro:content";

const [solidaryEntry] = await Astro.glob("../content/solidary.md");
const solidary = parseSolidaryFrontmatter(solidaryEntry?.frontmatter);
const siteDescription = solidary.description;

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const title = entry.data.title;
const description = entry.data.description ?? siteDescription;
const canonicalPath = `/${entry.slug}`;
const pageJavaScript = typeof entry.data.javascript === "string" ? entry.data.javascript.trim() : "";
const sanitizedPageJavaScript = pageJavaScript.replaceAll("</script", "<\\/script");
---

<Base pageTitle={title} description={description} canonicalPath={canonicalPath}>
  <article class="prose">
    <Content />
  </article>
  {sanitizedPageJavaScript && <script is:inline set:html={sanitizedPageJavaScript} />}
</Base>
